<view class="mine">
  <view wx:if="{{!currentUser}}" class="auth-card">
    <view class="auth-title">测试登录</view>
    <input class="input" placeholder="用户名" value="{{username}}" bindinput="onUsernameInput" />
    <input class="input" placeholder="密码" password value="{{password}}" bindinput="onPasswordInput" />
    <view class="auth-actions">
      <button class="primary-btn" bindtap="onLogin">登录</button>
      <button class="secondary-btn" bindtap="onRegister">注册</button>
    </view>
    <view class="hint">注册成功后会自动登录，可创建多个测试账号。</view>
  </view>

  <view wx:else>
    <view class="profile">
      <view>
        <view class="profile-name">{{currentUser.username}}</view>
        <view class="profile-sub">当前账号</view>
      </view>
      <button class="logout-btn" bindtap="onLogout">退出</button>
    </view>

    <view wx:if="{{users.length > 1}}" class="switch-box">
      <view class="section-title">切换账号</view>
      <view class="user-row">
        <view
          wx:for="{{users}}"
          wx:key="username"
          class="user-pill {{item.username === currentUser.username ? 'user-pill--active' : ''}}"
          data-username="{{item.username}}"
          bindtap="onSwitchUser"
        >{{item.username}}</view>
      </view>
    </view>

    <view class="tool-grid">
      <view class="tool-card" bindtap="onTapUpload">
        <view class="tool-title">上传短剧</view>
        <view class="tool-desc">选择视频并上传到 COS</view>
      </view>
      <view class="tool-card tool-card--rag" bindtap="onTapRag">
        <view class="tool-title">RAG 调用</view>
        <view class="tool-desc">模型A为互动点判断模型</view>
      </view>
    </view>

    <view class="tabs">
      <view class="tab {{activeTab === 'liked' ? 'tab--active' : ''}}" data-tab="liked" bindtap="onSelectTab">点赞</view>
      <view class="tab {{activeTab === 'favorites' ? 'tab--active' : ''}}" data-tab="favorites" bindtap="onSelectTab">收藏</view>
    </view>

    <view wx:if="{{activeTab === 'liked'}}" class="drama-list">
      <view wx:for="{{liked}}" wx:key="dramaId" class="record-card" data-id="{{item.dramaId}}" bindtap="onTapDrama">
        <image wx:if="{{item.coverUrl}}" class="record-cover" src="{{item.coverUrl}}" mode="aspectFill" />
        <view class="record-info">
          <view class="record-title">{{item.title}}</view>
          <view class="record-desc">{{item.description}}</view>
        </view>
      </view>
      <view wx:if="{{liked.length === 0}}" class="empty">还没有点赞短剧</view>
    </view>

    <view wx:if="{{activeTab === 'favorites'}}" class="drama-list">
      <view wx:for="{{favorites}}" wx:key="dramaId" class="record-card" data-id="{{item.dramaId}}" bindtap="onTapDrama">
        <image wx:if="{{item.coverUrl}}" class="record-cover" src="{{item.coverUrl}}" mode="aspectFill" />
        <view class="record-info">
          <view class="record-title">{{item.title}}</view>
          <view class="record-desc">{{item.description}}</view>
        </view>
      </view>
      <view wx:if="{{favorites.length === 0}}" class="empty">还没有收藏短剧</view>
    </view>
  </view>
</view>
