/* pages/play/index.wxss - 播放页样式 */
.container {
  width: 100vw;
  height: 100vh;
  background-color: #000;
  position: relative;
  overflow: hidden;
}

.loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
}

/* 视频铺满整屏；object-fit 由 JS 按视频方向切换（cover/contain） */
.drama-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: #000;
  transition: height 0.28s ease;
}

/* 评论展开时：视频等比缩到顶部，仍正常播放 */
.drama-video--mini {
  height: 42vh;
}

/* 点击层：覆盖视频，捕获空白处点击切换播放 */
.play-video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 8;
}

.play-video-overlay--native {
  bottom: 180rpx;
  bottom: calc(180rpx + constant(safe-area-inset-bottom));
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

.play-video-overlay--native .play-top-left,
.play-video-overlay--native .title-overlay,
.play-video-overlay--native .overlay,
.play-video-overlay--native .emotion-item,
.play-video-overlay--native .big-image,
.play-video-overlay--native .drama-social-actions,
.play-video-overlay--native .play-drama-info,
.play-video-overlay--native .branch-mask,
.play-video-overlay--native .action-mask,
.play-video-overlay--native .blackout,
.play-video-overlay--native .story-text,
.play-video-overlay--native .story-image,
.play-video-overlay--native .ep-mask,
.play-video-overlay--native .ep-panel,
.play-video-overlay--native .speed-boost-mask {
  pointer-events: auto;
}

.play-video-overlay--native .title-overlay,
.play-video-overlay--native .play-drama-info {
  bottom: 42rpx;
}

.play-video-overlay--native .drama-social-actions {
  bottom: 138rpx;
}

.play-video-overlay--native .overlay {
  bottom: 340rpx;
}

.tap-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 12;
}

.comment-close-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 42vh;
  z-index: 999;
}

/* 中央播放图标（暂停时） */
.center-play {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 70;
  width: 94rpx;
  height: 94rpx;
  margin-left: -47rpx;
  margin-top: -47rpx;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-play-tri {
  color: #fff;
  font-size: 44rpx;
  margin-left: 7rpx; /* 三角视觉居中微调 */
}

/* 拖动时居中显示 当前/总时长 */
.seek-time {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 50%;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

/* 底部进度条：透明热区加高，便于真机点击/拖动，可见细条贴底 */
.progress-track {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 28rpx;
  bottom: calc(28rpx + constant(safe-area-inset-bottom));
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  height: 48rpx;
  display: flex;
  align-items: flex-end;
  z-index: 90;
}

.progress-track--with-task-bars {
  bottom: 164rpx;
}

.progress-track--with-many-task-bars {
  bottom: 276rpx;
}

/* 可见进度条（热区底部的细条） */
.progress-bar {
  position: relative;
  width: 100%;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.28);
  transition: height 0.15s ease;
}

/* 拖动时加粗，反馈更明显 */
.progress-bar--active {
  height: 14rpx;
}

.progress-fill {
  position: relative;
  height: 100%;
  width: 0;
  background-color: #fff;
}

/* 进度滑块：便于抓取 */
.progress-knob {
  position: absolute;
  right: -16rpx;
  top: 50%;
  z-index: 2;
  width: 32rpx;
  height: 32rpx;
  margin-top: -16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background-color: #fff;
  box-shadow: 0 0 0 5rpx rgba(0, 0, 0, 0.22), 0 0 12rpx rgba(255, 255, 255, 0.76);
}

/* 标题：移到底部，贴近底部但在进度条/选集之上 */
.title-overlay {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 138rpx;
  bottom: calc(138rpx + constant(safe-area-inset-bottom));
  bottom: calc(138rpx + env(safe-area-inset-bottom));
  z-index: 73;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.title-overlay--with-task-bars {
  bottom: 294rpx;
}

.title-overlay--with-many-task-bars {
  bottom: 406rpx;
}

/* 二倍速提示 */
.speed-tip {
  position: absolute;
  left: 50%;
  top: 150rpx;
  z-index: 75;
  transform: translateX(-50%);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.52);
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.55);
}

.play-top-left {
  position: absolute;
  left: 20rpx;
  top: 92rpx;
  z-index: 96;
  max-width: 360rpx;
  display: flex;
  align-items: center;
  color: #fff;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.72);
}

.play-back {
  width: 48rpx;
  height: 56rpx;
  line-height: 50rpx;
  font-size: 50rpx;
  font-weight: 400;
}

.play-episode-label {
  min-width: 116rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin-left: 2rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.32);
  font-size: 27rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.speed-button {
  position: absolute;
  right: 28rpx;
  top: 96rpx;
  bottom: auto;
  z-index: 96;
  min-width: 128rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background-color: rgba(0, 0, 0, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  color: #fff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.34);
  box-sizing: border-box;
}

.speed-clock {
  width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.speed-label {
  line-height: 52rpx;
}

.speed-button--panel {
  top: 116rpx;
  bottom: auto;
}

.speed-menu {
  position: absolute;
  right: 28rpx;
  top: 156rpx;
  bottom: auto;
  z-index: 97;
  width: 140rpx;
  padding: 10rpx;
  border-radius: 16rpx;
  background-color: rgba(13, 15, 17, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.34);
}

.speed-menu--panel {
  top: 176rpx;
  bottom: auto;
}

.speed-option {
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.86);
  text-align: center;
  font-size: 23rpx;
  font-weight: 700;
}

.speed-option--active {
  background-color: rgba(255, 255, 255, 0.92);
  color: #111;
}

.drama-social-actions {
  position: absolute;
  right: 22rpx;
  bottom: 238rpx;
  z-index: 74;
  display: flex;
  flex-direction: column;
  gap: 44rpx;
  align-items: center;
}

.drama-social-btn {
  width: 76rpx;
  text-align: center;
  color: #fff;
}

.drama-social-icon {
  width: 70rpx;
  height: 66rpx;
  line-height: 66rpx;
  margin: 0 auto 2rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  color: #fff;
  font-size: 58rpx;
  font-weight: 900;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.72);
  box-shadow: none;
}

.drama-social-icon-comment {
  width: 52rpx;
  height: 48rpx;
  line-height: 38rpx;
  border-radius: 50%;
  background: #fff;
  color: #101010;
  font-size: 26rpx;
  letter-spacing: 1rpx;
  text-shadow: none;
}

.drama-social-icon-star {
  font-size: 62rpx;
}

.drama-social-icon-heart {
  font-size: 64rpx;
  color: #fff;
  font-family: Arial, sans-serif;
}

.drama-social-btn--active .drama-social-icon-heart {
  color: #ff3158;
  background: transparent;
  border-color: transparent;
  text-shadow: 0 4rpx 14rpx rgba(255, 49, 88, 0.44);
}

.drama-social-btn--active .drama-social-icon-star {
  color: #ff3158;
  background: transparent;
  border-color: transparent;
  text-shadow: 0 4rpx 14rpx rgba(255, 49, 88, 0.44);
}

.drama-social-text {
  font-size: 22rpx;
  font-weight: 800;
  text-shadow: 0 3rpx 9rpx rgba(0, 0, 0, 0.72);
}

.play-drama-info {
  position: absolute;
  left: 30rpx;
  right: 128rpx;
  bottom: 148rpx;
  bottom: calc(148rpx + constant(safe-area-inset-bottom));
  bottom: calc(148rpx + env(safe-area-inset-bottom));
  z-index: 126;
  min-height: 108rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  color: #fff;
}

.play-drama-info--with-task-bars {
  bottom: 268rpx;
}

.play-drama-info--with-many-task-bars {
  bottom: 380rpx;
}

.danmaku-send-btn {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin-bottom: 0;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  background: rgba(38, 40, 44, 0.86);
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.28);
}

.play-drama-name {
  max-width: 100%;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.72);
}

/* 选集入口 */
.episode-entry {
  position: absolute;
  left: 30rpx;
  bottom: 80rpx;
  bottom: calc(80rpx + constant(safe-area-inset-bottom));
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  z-index: 96;
  min-width: 112rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.34);
  font-size: 25rpx;
  font-weight: 900;
  color: #fff;
  box-sizing: border-box;
  text-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.7);
}

.episode-entry--with-task-bars {
  bottom: 212rpx;
}

.episode-entry--with-many-task-bars {
  bottom: 324rpx;
}

.play-task-bars {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 0;
  z-index: 60;
}

.play-task-bar {
  margin-top: 10rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  background-color: rgba(18, 22, 27, 0.88);
}

.play-task-bar-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: bold;
}

.play-task-bar-track {
  height: 8rpx;
  margin-top: 8rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.18);
}

.play-task-bar-fill {
  height: 100%;
  background-color: #27c46b;
}

.play-task-bar-rag .play-task-bar-fill {
  background-color: #2b87ff;
}

.play-task-bar-message {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #c3cbd4;
  font-size: 21rpx;
}

/* 选集面板 */
.ep-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 108;
  background-color: rgba(0, 0, 0, 0.42);
}

.ep-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 109;
  height: 58vh;
  box-sizing: border-box;
  padding: 26rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  background-color: rgba(31, 31, 31, 0.98);
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
}

.ep-handle {
  width: 82rpx;
  height: 8rpx;
  margin: 0 auto 30rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
}

.ep-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 104rpx;
  margin-bottom: 24rpx;
}

.ep-cover {
  width: 84rpx;
  height: 104rpx;
  flex-shrink: 0;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.12);
}

.ep-cover--empty {
  background: linear-gradient(135deg, #343434, #242424);
}

.ep-info {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.ep-title-line {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.ep-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #f7f7f7;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 40rpx;
}

.ep-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.45);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.ep-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 26rpx;
}

.ep-tag {
  height: 48rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 650;
  line-height: 48rpx;
}

.ep-range-tabs {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 54rpx;
  margin-bottom: 20rpx;
}

.ep-range {
  margin-right: 58rpx;
  color: rgba(255, 255, 255, 0.34);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 31rpx;
  font-weight: 750;
  line-height: 54rpx;
}

.ep-range--cur {
  color: #fff;
}

.ep-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items: flex-start;
  max-height: 488rpx;
  overflow: hidden;
}

.ep-item {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  margin: 0 12rpx 18rpx 0;
  padding: 0;
  border-radius: 10rpx;
  background-color: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 31rpx;
  font-weight: 650;
  line-height: 104rpx;
  text-align: center;
}

.ep-num {
  height: 104rpx;
  line-height: 104rpx;
  text-align: center;
}

.ep-item--cur {
  background-color: rgba(255, 129, 24, 0.18);
  color: #ff8a1e;
  font-weight: 800;
}

.ep-playing-mark {
  position: absolute;
  right: 18rpx;
  top: 14rpx;
  height: 20rpx;
  color: #ff7a18;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 20rpx;
}

.ep-fav-btn {
  position: absolute;
  left: 50%;
  bottom: calc(26rpx + env(safe-area-inset-bottom));
  width: 300rpx;
  height: 72rpx;
  margin-left: -150rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #ff9a28, #ff7a10);
  color: #fff;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 29rpx;
  font-weight: 850;
  line-height: 72rpx;
  text-align: center;
}

.ep-fav-btn--active {
  background: linear-gradient(90deg, #ffb13d, #ff8a1e);
}

/* ===== 分支弹窗 ===== */
.branch-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 120;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.branch-box {
  width: 560rpx;
  padding: 40rpx 32rpx;
  background-color: rgba(28, 28, 30, 0.96);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.branch-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 28rpx;
  text-align: center;
}

.branch-opt {
  width: 100%;
  margin-bottom: 20rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  background-color: #ff4d6d;
  border-radius: 48rpx;
}

/* 选过的错误项：置灰、不可选（点击已在 JS 守卫） */
.branch-opt--disabled {
  background-color: rgba(120, 120, 120, 0.45);
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 动作互动 ===== */
.action-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 120;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  background-color: rgba(0, 0, 0, 0.58);
}

.action-box {
  width: 540rpx;
  padding: 0;
  border-radius: 8rpx;
  background-color: transparent;
  text-align: center;
}

.action-btn {
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #35e878 0%, #20c964 100%);
  color: #062011;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
  border: 2rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.38), inset 0 2rpx 0 rgba(255, 255, 255, 0.35);
}

.action-video-lock {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 118;
  background-color: rgba(0, 0, 0, 0);
}

.speed-boost-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 122;
  background-color: rgba(0, 0, 0, 0.2);
}

.speed-boost-card {
  position: absolute;
  right: 44rpx;
  bottom: 250rpx;
  width: 240rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, rgba(255, 221, 88, 0.98) 0%, rgba(255, 153, 45, 0.98) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.54);
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.36), inset 0 2rpx 0 rgba(255, 255, 255, 0.42);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.speed-boost-rate {
  margin-right: 12rpx;
  color: #241304;
  font-size: 34rpx;
  font-weight: 900;
}

.speed-boost-text {
  color: #241304;
  font-size: 32rpx;
  font-weight: 800;
}

/* ===== 错误分支黑屏 ===== */
.blackout {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 124;
  background-color: #000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* 文案：默认透明，加 --in 后缓慢浮现 */
.blackout-text {
  width: 78%;
  text-align: center;
  font-size: 34rpx;
  line-height: 1.7;
  color: #fff;
  opacity: 0;
  transition: opacity 1.8s ease;
}

.blackout-text--in {
  opacity: 1;
}

/* 重新选择按钮：文字浮现后再淡入 */
.blackout-retry {
  margin-top: 56rpx;
  padding: 20rpx 56rpx;
  font-size: 30rpx;
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 48rpx;
  opacity: 0;
  transition: opacity 1.8s ease 0.6s;
}

.blackout-retry--in {
  opacity: 1;
}

/* ===== 生成内容社交条 ===== */
.story-social {
  position: absolute;
  right: 24rpx;
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.social-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 28rpx;
}

.social-ico {
  font-size: 60rpx;
  color: #fff;
}

.social-ico.liked {
  color: #ff4d6d;
}

.social-num {
  font-size: 24rpx;
  color: #fff;
  margin-top: 4rpx;
}

/* ===== 生成文本弹窗 ===== */
.story-text {
  position: absolute;
  left: 60rpx;
  right: 60rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 36rpx 32rpx;
  background-color: rgba(28, 28, 30, 0.96);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
}

.story-text-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.story-text-body {
  font-size: 28rpx;
  color: #ddd;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.story-text-close {
  align-self: center;
  padding: 14rpx 48rpx;
  font-size: 28rpx;
  color: #fff;
  background-color: #444;
  border-radius: 40rpx;
}

/* ===== 图片序列弹窗 ===== */
.story-image {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  top: 140rpx;
  z-index: 24;
  padding: 26rpx;
  border-radius: 8rpx;
  background-color: rgba(28, 28, 30, 0.96);
}

.story-image-title {
  margin-bottom: 18rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
}

.story-image-pic {
  width: 100%;
  height: 620rpx;
  background-color: #101214;
}

.story-image-empty {
  min-height: 260rpx;
  padding: 24rpx;
  color: #ffffff;
  font-size: 27rpx;
  line-height: 1.55;
  background-color: #101214;
}

.story-image-tools {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 18rpx;
  margin-bottom: 18rpx;
}

.story-image-tool {
  width: 156rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
}

.story-image-index {
  color: #cfd7df;
  font-size: 24rpx;
}

/* ===== 评论面板：位于缩小后视频下方（普通组件，可用 input/scroll-view） ===== */
.cmt-wrap {
  position: absolute;
  top: 42vh;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10020;
}

.cmt-panel {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 22rpx 28rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background-color: #1b1d1f;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -18rpx 44rpx rgba(0, 0, 0, 0.38);
}

.cmt-head {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
}

.cmt-collapse {
  position: absolute;
  left: 0;
  top: 4rpx;
  width: 86rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 22rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.1);
  font-size: 24rpx;
  font-weight: 800;
}

.cmt-title {
  color: rgba(255, 255, 255, 0.92);
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 800;
}

.cmt-search {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  line-height: 42rpx;
}

.cmt-search text {
  color: #4fa2ff;
}

.cmt-search-icon {
  margin-left: 4rpx;
  font-size: 28rpx;
}

.cmt-list {
  flex: 1;
  min-height: 0;
  margin-top: 20rpx;
  padding-right: 4rpx;
}

.cmt-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0 24rpx;
}

.cmt-avatar {
  flex-shrink: 0;
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  background: linear-gradient(135deg, #ff7aa8, #7b61ff);
  font-size: 30rpx;
  font-weight: 900;
}

.cmt-main {
  flex: 1;
  min-width: 0;
}

.cmt-nick {
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, 0.54);
  font-size: 27rpx;
  line-height: 36rpx;
}

.cmt-content {
  color: rgba(255, 255, 255, 0.9);
  font-size: 31rpx;
  line-height: 43rpx;
}

.cmt-meta {
  display: flex;
  gap: 28rpx;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.44);
  font-size: 23rpx;
  line-height: 34rpx;
}

.cmt-reply {
  color: rgba(255, 255, 255, 0.55);
}

.cmt-like {
  flex-shrink: 0;
  width: 58rpx;
  padding-top: 10rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.72);
}

.cmt-like-icon {
  font-size: 44rpx;
  line-height: 48rpx;
  font-family: Arial, sans-serif;
}

.cmt-like-count {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 28rpx;
}

.cmt-empty {
  padding: 52rpx 0;
  color: rgba(255, 255, 255, 0.52);
  font-size: 28rpx;
  line-height: 40rpx;
}

.cmt-input-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-top: 22rpx;
}

.cmt-input {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  padding: 0 26rpx;
  background-color: #2a2c2f;
  border-radius: 28rpx;
  color: #fff;
  font-size: 30rpx;
}

.cmt-send {
  flex-shrink: 0;
  width: 92rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 26rpx;
  text-align: center;
  color: #fff;
  background: #36393f;
  font-size: 28rpx;
  font-weight: 800;
}

/* 高光互动浮层：左侧中下竖排（右下角留给大图） */
.overlay {
  position: absolute;
  left: 28rpx;
  bottom: 520rpx;
  z-index: 40;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 单个情绪按钮 */
.emotion-item {
  width: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 22rpx;
  overflow: visible;
  transition: transform 0.2s ease;
  transform-origin: left center;
}

/* 点击放大动效（cover-view 仅支持简单 transform） */
.emotion-item--anim {
  transform: scale(1.18);
}

/* 图标 + ×计数 一行 */
.emotion-row {
  width: 180rpx;
  height: 92rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  overflow: visible;
}

.emotion-icon {
  width: 76rpx;
  height: 76rpx;
}

.emotion-count {
  margin-left: 6rpx;
  min-width: 58rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.65);
}

/* 表情爆发：起始在底部，transform/opacity 由内联 style 控制，向上飘并淡出 */
.float {
  position: absolute;
  bottom: 140rpx;
  transition: transform 2.4s ease-out, opacity 2.4s ease-out;
}

.float-icon {
  width: 100%;
  height: 100%;
}

.danmaku-text {
  position: absolute;
  left: 750rpx;
  z-index: 42;
  max-width: 960rpx;
  padding: 0;
  background: transparent;
  color: #fff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 34rpx;
  white-space: nowrap;
  text-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.9), 0 0 2rpx rgba(0, 0, 0, 0.95);
  transform: translateX(0);
  transition: transform 5.6s linear;
}

.danmaku-text--move {
  transform: translateX(-1280rpx);
}

.danmaku-text--user {
  padding: 4rpx 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.18);
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.26);
}

.danmaku-text--stat,
.danmaku-text--highlight {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 213, 64, 0.94);
  color: #161006;
  font-size: 23rpx;
  font-weight: 900;
  text-shadow: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.24);
}

/* 右上角大图：一动一动（JS 每 350ms 切换 beat，配合 transition） */
.big-image {
  position: absolute;
  right: 20rpx;
  top: 100rpx;
  z-index: 58;
  width: 320rpx;
  height: 320rpx;
  transform-origin: center center;
  transition: transform 0.26s cubic-bezier(0.2, 0.9, 0.25, 1.35);
}

.big-image--beat {
  transform: scale(1.28) rotate(-12deg) translate(-10rpx, 6rpx);
}

.empty {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #666;
}
